<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link rel="apple-touch-icon" href="/logo.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#0b1838">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="diary2-weekly-report-page">
    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container-fluid px-0">
            <div class="topbar-main">
                <a href="/dashboard" class="navbar-brand brand-mark">
                    <span class="brand-kicker">Crusher Management</span>
                    <span class="brand-name">KOTHAVALE CRUSHER</span>
                </a>
                <div class="page-title-block">
                    <h1><%= pageTitle %></h1>
                </div>
            </div>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#site-nav" aria-controls="site-nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="site-nav">
                <div class="navbar-nav app-nav ms-auto">
                    <a class="nav-link" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/diary1">Diary 1</a>
                    <a class="nav-link" href="/diary2">Diary 2</a>
                    <a class="nav-link" href="/trash">Trash</a>
                    <a class="nav-link" href="/logout">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <section class="hero-card compact-nav-strip">
        <div class="hero-actions dashboard-quick-links">
            <a class="secondary-btn" href="/diary1">Diary 1</a>
            <a class="secondary-btn" href="/diary2">Diary 2</a>
        </div>
    </section>

    <main class="page-shell">
        <section class="panel">
            <div class="panel-heading">
                <h3><%= panelTitle %></h3>
                <a href="/diary2">Back to Diary 2</a>
            </div>

            <% if (!activePeriod) { %>
                <p class="empty-state">No Diary 2 entries have been added yet.</p>
            <% } else { %>
                <article class="weekly-total-panel">
                    <div class="weekly-total-nav compact-week-nav">
                        <div class="weekly-total-range">
                            <span class="eyebrow"><%= pickerEyebrow %></span>
                            <button type="button" class="week-picker-trigger" data-week-picker-open="diary2-period-picker">
                                <span><%= activePeriod.periodLabel %></span>
                            </button>
                        </div>

                        <dialog class="week-picker-dialog" id="diary2-period-picker">
                            <div class="week-picker-dialog-head">
                                <h5><%= pickerTitle %></h5>
                                <button type="button" class="week-picker-close" data-week-picker-close="diary2-period-picker" aria-label="Close">x</button>
                            </div>
                            <div class="week-picker-list">
                                <% periods.forEach((period) => { %>
                                    <a
                                        href="<%= reportPath %>?<%= periodQueryName %>=<%= period.periodKey %>"
                                        class="week-picker-link <%= period.periodKey === selectedPeriodKey ? 'active-week-link' : '' %>">
                                        <%= period.periodLabel %>
                                    </a>
                                <% }) %>
                            </div>
                        </dialog>
                    </div>

                    <div class="diary2-compact-card">
                        <div class="diary2-summary-block">
                            <p><strong>Rawal M</strong> - <%= activePeriod.rawalForMachine %> <strong>O</strong> - <%= activePeriod.rawalForOutside %></p>
                            <p><strong>Dalni</strong> - <%= activePeriod.dalni %></p>
                            <p><strong>Dabar</strong> - <%= activePeriod.dabar %></p>
                            <p><strong>Loader</strong> -> <strong>T</strong> - <%= activePeriod.loaderTractor %> <strong>D</strong> - <%= activePeriod.loaderDumper %></p>
                            <p><strong>Holes</strong> - <%= activePeriod.holes %></p>
                            <p><strong>Tr Trip</strong> - <%= activePeriod.tractorTrip %></p>
                            <p><strong>Salary Paid</strong> - <%= activePeriod.salaryPaidToPiraji %></p>
                            <p><strong>Diesel Expense</strong> - <%= activePeriod.dieselExpense %></p>
                            <p><strong>Maintenance Expense</strong> - <%= activePeriod.maintenanceExpense %></p>
                            <p><strong>Other Expense</strong> - <%= activePeriod.otherExpense %></p>
                        </div>

                        <section class="weekly-detail-card">
                            <div class="weekly-detail-head">
                                <h5>Hawari Detail</h5>
                            </div>
                            <div class="table-wrap">
                                <table class="compact-info-table hawari-detail-table">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>T</th>
                                            <th>D</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Ranga</td>
                                            <td><%= activePeriod.hawariTotals.tractor.ranga %></td>
                                            <td><%= activePeriod.hawariTotals.dumper.ranga %></td>
                                        </tr>
                                        <tr>
                                            <td>Piraji</td>
                                            <td><%= activePeriod.hawariTotals.tractor.piraji %></td>
                                            <td><%= activePeriod.hawariTotals.dumper.piraji %></td>
                                        </tr>
                                        <tr>
                                            <td>Dada</td>
                                            <td><%= activePeriod.hawariTotals.tractor.dada %></td>
                                            <td><%= activePeriod.hawariTotals.dumper.dada %></td>
                                        </tr>
                                        <tr>
                                            <td>Rama</td>
                                            <td><%= activePeriod.hawariTotals.tractor.rama %></td>
                                            <td><%= activePeriod.hawariTotals.dumper.rama %></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </section>

                        <section class="weekly-detail-card">
                            <div class="weekly-detail-head">
                                <h5>Salary Detail</h5>
                            </div>
                            <div class="table-wrap">
                                <table class="compact-info-table hawari-detail-table">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Mukadam</td>
                                            <td><%= activePeriod.salaryTotals.mukadam %></td>
                                        </tr>
                                        <tr>
                                            <td>Piraji</td>
                                            <td><%= activePeriod.salaryTotals.piraji %></td>
                                        </tr>
                                        <tr>
                                            <td>Ranga</td>
                                            <td><%= activePeriod.salaryTotals.ranga %></td>
                                        </tr>
                                        <tr>
                                            <td>Dada</td>
                                            <td><%= activePeriod.salaryTotals.dada %></td>
                                        </tr>
                                        <tr>
                                            <td>Rama</td>
                                            <td><%= activePeriod.salaryTotals.rama %></td>
                                        </tr>
                                        <tr>
                                            <td>Hole</td>
                                            <td><%= activePeriod.salaryTotals.hole %></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Total Salary</strong></td>
                                            <td><strong><%= activePeriod.salaryTotals.totalToGive %></strong></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </section>

                        <section class="weekly-detail-card">
                            <div class="weekly-detail-head">
                                <h5>Total Income</h5>
                            </div>
                            <div class="diary2-summary-block">
                                <p><strong>Total Income</strong> - <%= activePeriod.incomeTotal %></p>
                                <p><strong>Total Expense</strong> - <%= activePeriod.expenseTotals.totalExpense %></p>
                            </div>
                        </section>
                    </div>
                </article>
            <% } %>
        </section>
    </main>
    <footer class="site-footer">
        <p>Made with &#10084; by Champ</p>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/app.js"></script>
</body>
</html>
