<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Diary 2 Weekly Report</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link rel="apple-touch-icon" href="/logo.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#0b1838">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <header class="topbar">
        <div class="topbar-main">
            <a href="/dashboard" class="brand-mark">
                <span class="brand-kicker">Crusher Management</span>
                <span class="brand-name">KOTHAVALE CRUSHER</span>
            </a>
            <div class="page-title-block">
                <h1>Diary 2 Weekly Report</h1>
            </div>
        </div>
        <button type="button" class="nav-toggle" aria-expanded="false" aria-controls="site-nav">
            Menu
        </button>
        <nav class="nav-links" id="site-nav">
            <a href="/dashboard">Dashboard</a>
            <a href="/diary1">Diary 1</a>
            <a href="/diary2">Diary 2</a>
            <a href="/trash">Trash</a>
            <a href="/logout">Logout</a>
        </nav>
    </header>

    <main class="page-shell">
        <section class="panel">
            <div class="panel-heading">
                <h3>Friday-to-Friday Report</h3>
                <a href="/diary2">Back to Diary 2</a>
            </div>

            <% if (!activeDiary2Week) { %>
                <p class="empty-state">No Diary 2 entries have been added yet.</p>
            <% } else { %>
                <article class="weekly-total-panel">
                    <div class="weekly-total-nav">
                        <% if (newerDiary2Week) { %>
                            <a href="/diary2/weekly-report?week=<%= newerDiary2Week.weekKey %>" class="secondary-btn weekly-nav-btn">Newer Week</a>
                        <% } else { %>
                            <span class="secondary-btn weekly-nav-btn disabled-week-link">Newer Week</span>
                        <% } %>

                        <div class="weekly-total-range">
                            <span class="eyebrow">Salary Week</span>
                            <h4><%= activeDiary2Week.weekLabel %></h4>
                        </div>

                        <% if (olderDiary2Week) { %>
                            <a href="/diary2/weekly-report?week=<%= olderDiary2Week.weekKey %>" class="secondary-btn weekly-nav-btn">Previous Week</a>
                        <% } else { %>
                            <span class="secondary-btn weekly-nav-btn disabled-week-link">Previous Week</span>
                        <% } %>
                    </div>

                    <div class="diary2-compact-card">
                        <div class="diary2-summary-table">
                            <div class="summary-head">
                                <span class="rawal-head">Rawal</span>
                                <span>Dalni</span>
                                <span>Dabar</span>
                            </div>
                            <div class="summary-subhead">
                                <span>Mah</span>
                                <span>Out</span>
                                <span>Dalni</span>
                                <span>Dabar</span>
                            </div>
                            <div class="summary-values">
                                <span><%= activeDiary2Week.rawalForMachine %></span>
                                <span><%= activeDiary2Week.rawalForOutside %></span>
                                <span><%= activeDiary2Week.dalni %></span>
                                <span><%= activeDiary2Week.dabar %></span>
                            </div>
                        </div>

                        <div class="diary2-footer-lines">
                            <p><strong>Loader -> </strong><strong>T</strong> - <%= activeDiary2Week.loaderTractor %> <strong>D</strong> - <%= activeDiary2Week.loaderDumper %></p>
                            <p><strong>Holes</strong> - <%= activeDiary2Week.holes %></p>
                            <p><strong>Tr Trip</strong> - <%= activeDiary2Week.tractorTrip %></p>
                            <p><strong>Piraji Salary</strong> - <%= activeDiary2Week.salaryPaidToPiraji %></p>
                        </div>
                    </div>

                    <div class="weekly-detail-layout">
                        <section class="weekly-detail-card">
                            <div class="weekly-detail-head">
                                <h5>Hawari Detail</h5>
                            </div>
                            <div class="table-wrap">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>T</th>
                                            <th>D</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Ranga</td>
                                            <td><%= activeDiary2Week.hawariTotals.tractor.ranga %></td>
                                            <td><%= activeDiary2Week.hawariTotals.dumper.ranga %></td>
                                        </tr>
                                        <tr>
                                            <td>Piraji</td>
                                            <td><%= activeDiary2Week.hawariTotals.tractor.piraji %></td>
                                            <td><%= activeDiary2Week.hawariTotals.dumper.piraji %></td>
                                        </tr>
                                        <tr>
                                            <td>Dada</td>
                                            <td><%= activeDiary2Week.hawariTotals.tractor.dada %></td>
                                            <td><%= activeDiary2Week.hawariTotals.dumper.dada %></td>
                                        </tr>
                                        <tr>
                                            <td>Rama</td>
                                            <td><%= activeDiary2Week.hawariTotals.tractor.rama %></td>
                                            <td><%= activeDiary2Week.hawariTotals.dumper.rama %></td>
                                        </tr>
                                        <tr>
                                            <td>Other</td>
                                            <td><%= activeDiary2Week.hawariTotals.tractor.other %></td>
                                            <td><%= activeDiary2Week.hawariTotals.dumper.other %></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Total</strong></td>
                                            <td><strong><%= activeDiary2Week.tractorHawari %></strong></td>
                                            <td><strong><%= activeDiary2Week.dumperHawari %></strong></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                    </div>
                </article>
            <% } %>
        </section>
    </main>
    <footer class="site-footer">
        <p>Made with &#10084; by Champ</p>
    </footer>
    <script src="/app.js"></script>
</body>
</html>
