<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Diary 2 Weekly Report</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link rel="apple-touch-icon" href="/logo.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#0b1838">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <header class="topbar">
        <div class="topbar-main">
            <a href="/dashboard" class="brand-mark">
                <span class="brand-kicker">Crusher Management</span>
                <span class="brand-name">KOTHAVALE CRUSHER</span>
            </a>
            <div class="page-title-block">
                <h1>Diary 2 Weekly Report</h1>
            </div>
        </div>
        <button type="button" class="nav-toggle" aria-expanded="false" aria-controls="site-nav">
            Menu
        </button>
        <nav class="nav-links" id="site-nav">
            <a href="/dashboard">Dashboard</a>
            <a href="/diary1">Diary 1</a>
            <a href="/diary2">Diary 2</a>
            <a href="/trash">Trash</a>
            <a href="/logout">Logout</a>
        </nav>
    </header>

    <main class="page-shell">
        <section class="panel">
            <div class="panel-heading">
                <h3>Friday-to-Friday Report</h3>
                <a href="/diary2">Back to Diary 2</a>
            </div>

            <% if (!activeDiary2Week) { %>
                <p class="empty-state">No Diary 2 entries have been added yet.</p>
            <% } else { %>
                <article class="weekly-total-panel">
                    <div class="weekly-total-nav compact-week-nav">
                        <div class="weekly-total-range">
                            <span class="eyebrow">Salary Week</span>
                            <button type="button" class="week-picker-trigger" data-week-picker-open="diary2-week-picker">
                                <span><%= activeDiary2Week.weekLabel %></span>
                            </button>
                        </div>

                        <dialog class="week-picker-dialog" id="diary2-week-picker">
                            <div class="week-picker-dialog-head">
                                <h5>Select Week</h5>
                                <button type="button" class="week-picker-close" data-week-picker-close="diary2-week-picker" aria-label="Close">x</button>
                            </div>
                            <div class="week-picker-list">
                                <% weeklyDiary2.forEach((week) => { %>
                                    <a
                                        href="/diary2/weekly-report?week=<%= week.weekKey %>"
                                        class="week-picker-link <%= week.weekKey === selectedDiary2WeekKey ? 'active-week-link' : '' %>">
                                        <%= week.weekLabel %>
                                    </a>
                                <% }) %>
                            </div>
                        </dialog>
                    </div>

                    <div class="diary2-compact-card">
                        <div class="diary2-summary-block">
                            <p><strong>Rawal M</strong> - <%= activeDiary2Week.rawalForMachine %> <strong>O</strong> - <%= activeDiary2Week.rawalForOutside %></p>
                            <p><strong>Dalni</strong> - <%= activeDiary2Week.dalni %></p>
                            <p><strong>Dabar</strong> - <%= activeDiary2Week.dabar %></p>
                            <p><strong>Loader</strong> -> <strong>T</strong> - <%= activeDiary2Week.loaderTractor %> <strong>D</strong> - <%= activeDiary2Week.loaderDumper %></p>
                            <p><strong>Holes</strong> - <%= activeDiary2Week.holes %></p>
                            <p><strong>Tr Trip</strong> - <%= activeDiary2Week.tractorTrip %></p>
                            <p><strong>Piraji Salary</strong> - <%= activeDiary2Week.salaryPaidToPiraji %></p>
                        </div>

                        <section class="weekly-detail-card">
                            <div class="weekly-detail-head">
                                <h5>Hawari Detail</h5>
                            </div>
                            <div class="table-wrap">
                                <table class="compact-info-table hawari-detail-table">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>T</th>
                                            <th>D</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Ranga</td>
                                            <td><%= activeDiary2Week.hawariTotals.tractor.ranga %></td>
                                            <td><%= activeDiary2Week.hawariTotals.dumper.ranga %></td>
                                        </tr>
                                        <tr>
                                            <td>Piraji</td>
                                            <td><%= activeDiary2Week.hawariTotals.tractor.piraji %></td>
                                            <td><%= activeDiary2Week.hawariTotals.dumper.piraji %></td>
                                        </tr>
                                        <tr>
                                            <td>Dada</td>
                                            <td><%= activeDiary2Week.hawariTotals.tractor.dada %></td>
                                            <td><%= activeDiary2Week.hawariTotals.dumper.dada %></td>
                                        </tr>
                                        <tr>
                                            <td>Rama</td>
                                            <td><%= activeDiary2Week.hawariTotals.tractor.rama %></td>
                                            <td><%= activeDiary2Week.hawariTotals.dumper.rama %></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                    </div>
                </article>
            <% } %>
        </section>
    </main>
    <footer class="site-footer">
        <p>Made with &#10084; by Champ</p>
    </footer>
    <script src="/app.js"></script>
</body>
</html>
