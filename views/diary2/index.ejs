<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Diary 2</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link rel="apple-touch-icon" href="/logo.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#0b1838">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="diary2-index-page">
    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container-fluid px-0">
            <div class="topbar-main">
                <a href="/dashboard" class="navbar-brand brand-mark">
                    <span class="brand-kicker">Crusher Management</span>
                    <span class="brand-name">KOTHAVALE CRUSHER</span>
                </a>
                <div class="page-title-block">
                    <h1>Diary 2</h1>
                </div>
            </div>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#site-nav" aria-controls="site-nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="site-nav">
                <div class="navbar-nav app-nav ms-auto">
                    <a class="nav-link" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/diary1">Diary 1</a>
                    <a class="nav-link" href="/diary2">Diary 2</a>
                    <a class="nav-link" href="/trash">Trash</a>
                    <a class="nav-link" href="/logout">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <section class="hero-card compact-nav-strip">
        <div class="hero-actions dashboard-quick-links">
            <a class="secondary-btn" href="/diary1">Diary 1</a>
            <a class="secondary-btn" href="/diary2">Diary 2</a>
        </div>
    </section>

    <main class="page-shell">
        <section class="hero-card">
            <div class="hero-actions">
                <a class="primary-btn" href="/diary2/new">Add Entry</a>
                <a class="secondary-btn" href="/diary2/weekly-report">Weekly Report</a>
                <a class="secondary-btn" href="/diary2/monthly-report">Monthly Report</a>
                <a class="secondary-btn" href="/diary2/yearly-report">Yearly Report</a>
            </div>
        </section>

        <section class="panel">
            <% const diary2BaseQuery = new URLSearchParams(); %>
            <% diary2BaseQuery.set("limit", pagination.limit); %>
            <% const buildDiary2PageUrl = (pageNumber) => {
                const params = new URLSearchParams(diary2BaseQuery);
                params.set("page", pageNumber);
                return `/diary2?${params.toString()}`;
            }; %>
            <div class="panel-heading">
                <h3>All Entries</h3>
                <div class="panel-tools">
                    <span class="muted"><%= pagination.totalRecords %> records</span>
                </div>
            </div>

            <% if (!data.length) { %>
                <p class="empty-state">No entries yet. Add your first Diary 2 entry.</p>
            <% } else { %>
                <div class="day-card-list">
                    <% data.forEach((entry) => { %>
                        <article class="day-entry-card">
                            <div class="record-day-header">
                                <h4><%= formatDateDisplay(entry.entryDate) %> <span class="muted"><%= entry.day %></span></h4>
                                <a href="/diary2/<%= entry._id %>/edit" class="inline-edit-link">Edit</a>
                            </div>

                            <div class="diary2-compact-card">
                                <div class="diary2-summary-block">
                                    <p><strong>Rawal M</strong> - <%= entry.rawalForMachine %> <strong>O</strong> - <%= entry.rawalForOutside %></p>
                                    <p><strong>Dalni</strong> - <%= entry.dalni %></p>
                                    <p><strong>Dabar</strong> - <%= entry.dabar %></p>
                                    <p><strong>Loader</strong> -> <strong>T</strong> - <%= entry.loaderTractor ?? entry.loaderQty ?? 0 %> <strong>D</strong> - <%= entry.loaderDumper ?? 0 %></p>
                                    <p><strong>Holes</strong> - <%= entry.holes %></p>
                                    <p><strong>Tr Trip</strong> - <%= entry.tractorTrip || 0 %></p>
                                    <p><strong>Salary Paid</strong> - <%= entry.salaryPaidToPiraji || 0 %></p>
                                    <p><strong>Diesel Expense</strong> - <%= entry.dieselExpense || 0 %></p>
                                    <p><strong>Maintenance Expense</strong> - <%= entry.maintenanceExpense || 0 %></p>
                                    <p><strong>Other Expense</strong> - <%= entry.otherExpense || 0 %></p>
                                </div>

                                <section class="weekly-detail-card">
                                    <div class="weekly-detail-head">
                                        <h5>Hawari Detail</h5>
                                    </div>
                                    <div class="table-wrap">
                                        <table class="compact-info-table hawari-detail-table">
                                            <thead>
                                                <tr>
                                                    <th>Name</th>
                                                    <th>T</th>
                                                    <th>D</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>Ranga</td>
                                                    <td><%= entry.tractorHawari.ranga %></td>
                                                    <td><%= entry.dumperHawari.ranga %></td>
                                                </tr>
                                                <tr>
                                                    <td>Piraji</td>
                                                    <td><%= entry.tractorHawari.piraji %></td>
                                                    <td><%= entry.dumperHawari.piraji %></td>
                                                </tr>
                                                <tr>
                                                    <td>Dada</td>
                                                    <td><%= entry.tractorHawari.dada %></td>
                                                    <td><%= entry.dumperHawari.dada %></td>
                                                </tr>
                                                <tr>
                                                    <td>Rama</td>
                                                    <td><%= entry.tractorHawari.rama %></td>
                                                    <td><%= entry.dumperHawari.rama %></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </section>

                                <section class="weekly-detail-card">
                                    <div class="weekly-detail-head">
                                        <h5>Salary Detail</h5>
                                    </div>
                                    <div class="table-wrap">
                                        <table class="compact-info-table hawari-detail-table">
                                            <thead>
                                                <tr>
                                                    <th>Name</th>
                                                    <th>Total</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>Mukadam</td>
                                                    <td><%= entry.salaryTotals.mukadam %></td>
                                                </tr>
                                                <tr>
                                                    <td>Piraji</td>
                                                    <td><%= entry.salaryTotals.piraji %></td>
                                                </tr>
                                                <tr>
                                                    <td>Ranga</td>
                                                    <td><%= entry.salaryTotals.ranga %></td>
                                                </tr>
                                                <tr>
                                                    <td>Dada</td>
                                                    <td><%= entry.salaryTotals.dada %></td>
                                                </tr>
                                                <tr>
                                                    <td>Rama</td>
                                                    <td><%= entry.salaryTotals.rama %></td>
                                                </tr>
                                                <tr>
                                                    <td>Hole</td>
                                                    <td><%= entry.salaryTotals.hole %></td>
                                                </tr>
                                                <tr>
                                                    <td><strong>Total Salary</strong></td>
                                                    <td><strong><%= entry.salaryTotals.totalToGive %></strong></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </section>

                                <section class="weekly-detail-card">
                                    <div class="weekly-detail-head">
                                        <h5>Total Income</h5>
                                    </div>
                                    <div class="diary2-summary-block">
                                        <p><strong>Total Income</strong> - <%= entry.incomeTotal %></p>
                                        <p><strong>Total Expense</strong> - <%= entry.expenseTotals.totalExpense %></p>
                                    </div>
                                </section>
                            </div>
                        </article>
                    <% }) %>
                </div>

                <div class="pagination-bar">
                    <span class="muted">Page <%= pagination.page %> of <%= pagination.totalPages %></span>
                    <div class="pagination-actions">
                        <% if (pagination.hasPreviousPage) { %>
                            <a class="secondary-btn" href="<%= buildDiary2PageUrl(pagination.previousPage) %>">Previous</a>
                        <% } else { %>
                            <span class="secondary-btn pagination-disabled" aria-disabled="true">Previous</span>
                        <% } %>

                        <% if (pagination.hasNextPage) { %>
                            <a class="secondary-btn" href="<%= buildDiary2PageUrl(pagination.nextPage) %>">Next</a>
                        <% } else { %>
                            <span class="secondary-btn pagination-disabled" aria-disabled="true">Next</span>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </section>
    </main>
    <footer class="site-footer">
        <p>Made with &#10084; by Champ</p>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/app.js"></script>
</body>
</html>
