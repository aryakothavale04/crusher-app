<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crusher Dashboard</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link rel="apple-touch-icon" href="/logo.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#0b1838">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container-fluid px-0">
            <div class="topbar-main">
                <a href="/dashboard" class="navbar-brand brand-mark">
                    <span class="brand-kicker">Crusher Management</span>
                    <span class="brand-name">KOTHAVALE CRUSHER</span>
                </a>
                <div class="page-title-block">
                    <h1>Dashboard</h1>
                </div>
            </div>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#site-nav" aria-controls="site-nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="site-nav">
                <div class="navbar-nav app-nav ms-auto">
                    <a class="nav-link" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/diary1">Diary 1</a>
                    <a class="nav-link" href="/diary2">Diary 2</a>
                    <a class="nav-link" href="/trash">Trash</a>
                    <a class="nav-link" href="/logout">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="page-shell">
        <section class="hero-card compact-nav-strip">
            <div class="hero-actions dashboard-quick-links">
                <a class="secondary-btn" href="/diary1">Diary 1</a>
                <a class="secondary-btn" href="/diary2">Diary 2</a>
            </div>
        </section>

        <section class="panel-grid">
            <article class="panel">
                <% const dashboardBaseQuery = new URLSearchParams(); %>
                <% if (selectedDiary2WeekKey) { dashboardBaseQuery.set("week", selectedDiary2WeekKey); } %>
                <% dashboardBaseQuery.set("unpaidLimit", pendingDiary1Pagination.limit); %>
                <% const buildDashboardUnpaidPageUrl = (pageNumber) => {
                    const params = new URLSearchParams(dashboardBaseQuery);
                    params.set("unpaidPage", pageNumber);
                    return `/dashboard?${params.toString()}`;
                }; %>
                <% const buildDashboardWeekUrl = (weekKey) => {
                    const params = new URLSearchParams(dashboardBaseQuery);
                    params.set("week", weekKey);
                    params.set("unpaidPage", pendingDiary1Pagination.page);
                    return `/dashboard?${params.toString()}`;
                }; %>
                <div class="panel-heading keep-inline-heading">
                    <h3>Weekly Total</h3>
                    <a href="/diary2" class="inline-edit-link">View all</a>
                </div>

                <% if (!activeDiary2Week) { %>
                    <p class="empty-state">No Diary 2 entries have been added yet.</p>
                    <% } else { %>
                        <article class="weekly-total-panel">
                            <div class="weekly-total-nav compact-week-nav">
                                <div class="weekly-total-range">
                                    <span class="eyebrow">Salary Week</span>
                                    <button type="button" class="week-picker-trigger" data-week-picker-open="dashboard-week-picker">
                                        <span><%= activeDiary2Week.weekLabel %></span>
                                    </button>
                                </div>

                                <dialog class="week-picker-dialog" id="dashboard-week-picker">
                                    <div class="week-picker-dialog-head">
                                        <h5>Select Week</h5>
                                        <button type="button" class="week-picker-close" data-week-picker-close="dashboard-week-picker" aria-label="Close">x</button>
                                    </div>
                                    <div class="week-picker-list">
                                        <% weeklyDiary2.forEach((week) => { %>
                                            <a
                                                href="<%= buildDashboardWeekUrl(week.weekKey) %>"
                                                class="week-picker-link <%= week.weekKey === selectedDiary2WeekKey ? 'active-week-link' : '' %>">
                                                <%= week.weekLabel %>
                                            </a>
                                        <% }) %>
                                    </div>
                                </dialog>
                            </div>

                            <div class="diary2-compact-card">
                                <div class="diary2-summary-block">
                                    <p><strong>Rawal M</strong> - <%= activeDiary2Week.rawalForMachine %> <strong>O</strong> - <%= activeDiary2Week.rawalForOutside %></p>
                                    <p><strong>Dalni</strong> - <%= activeDiary2Week.dalni %></p>
                                    <p><strong>Dabar</strong> - <%= activeDiary2Week.dabar %></p>
                                    <p><strong>Loader</strong> -> <strong>T</strong> - <%=
                                            activeDiary2Week.loaderTractor %> <strong>D</strong> - <%=
                                                activeDiary2Week.loaderDumper %>
                                    </p>
                                    <p><strong>Holes</strong> - <%= activeDiary2Week.holes %>
                                    </p>
                                    <p><strong>Tr Trip</strong> - <%= activeDiary2Week.tractorTrip %>
                                    </p>
                                    <p><strong>Salary Paid</strong> - <%= activeDiary2Week.salaryPaidToPiraji %>
                                    </p>
                                    <p><strong>Diesel Expense</strong> - <%= activeDiary2Week.dieselExpense %>
                                    </p>
                                    <p><strong>Maintenance Expense</strong> - <%= activeDiary2Week.maintenanceExpense %>
                                    </p>
                                    <p><strong>Other Expense</strong> - <%= activeDiary2Week.otherExpense %>
                                    </p>
                                </div>

                                <section class="weekly-detail-card">
                                    <div class="weekly-detail-head">
                                        <h5>Hawari Detail</h5>
                                    </div>
                                    <div class="table-wrap">
                                        <table class="compact-info-table hawari-detail-table">
                                            <thead>
                                                <tr>
                                                    <th>Name</th>
                                                    <th>T</th>
                                                    <th>D</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>Ranga</td>
                                                    <td>
                                                        <%= activeDiary2Week.hawariTotals.tractor.ranga %>
                                                    </td>
                                                    <td>
                                                        <%= activeDiary2Week.hawariTotals.dumper.ranga %>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Piraji</td>
                                                    <td>
                                                        <%= activeDiary2Week.hawariTotals.tractor.piraji %>
                                                    </td>
                                                    <td>
                                                        <%= activeDiary2Week.hawariTotals.dumper.piraji %>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Dada</td>
                                                    <td>
                                                        <%= activeDiary2Week.hawariTotals.tractor.dada %>
                                                    </td>
                                                    <td>
                                                        <%= activeDiary2Week.hawariTotals.dumper.dada %>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Rama</td>
                                                    <td>
                                                        <%= activeDiary2Week.hawariTotals.tractor.rama %>
                                                    </td>
                                                    <td>
                                                        <%= activeDiary2Week.hawariTotals.dumper.rama %>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </section>

                                <section class="weekly-detail-card">
                                    <div class="weekly-detail-head">
                                        <h5>Salary Detail</h5>
                                    </div>
                                    <div class="table-wrap">
                                        <table class="compact-info-table hawari-detail-table">
                                            <thead>
                                                <tr>
                                                    <th>Name</th>
                                                    <th>Total</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>Mukadam</td>
                                                    <td><%= activeDiary2Week.salaryTotals.mukadam %></td>
                                                </tr>
                                                <tr>
                                                    <td>Piraji</td>
                                                    <td><%= activeDiary2Week.salaryTotals.piraji %></td>
                                                </tr>
                                                <tr>
                                                    <td>Ranga</td>
                                                    <td><%= activeDiary2Week.salaryTotals.ranga %></td>
                                                </tr>
                                                <tr>
                                                    <td>Dada</td>
                                                    <td><%= activeDiary2Week.salaryTotals.dada %></td>
                                                </tr>
                                                <tr>
                                                    <td>Rama</td>
                                                    <td><%= activeDiary2Week.salaryTotals.rama %></td>
                                                </tr>
                                                <tr>
                                                    <td>Hole</td>
                                                    <td><%= activeDiary2Week.salaryTotals.hole %></td>
                                                </tr>
                                                <tr>
                                                    <td><strong>Total Salary</strong></td>
                                                    <td><strong><%= activeDiary2Week.salaryTotals.totalToGive %></strong></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </section>

                                <section class="weekly-detail-card">
                                    <div class="weekly-detail-head">
                                        <h5>Total Income</h5>
                                    </div>
                                    <div class="diary2-summary-block">
                                        <p><strong>Total Income</strong> - <%= activeDiary2Week.incomeTotal %></p>
                                        <p><strong>Total Expense</strong> - <%= activeDiary2Week.expenseTotals.totalExpense %></p>
                                    </div>
                                </section>
                            </div>
                        </article>
                        <% } %>
            </article>

            <article class="panel">
                <div class="panel-heading keep-inline-heading">
                    <h3>Unpaid Entries</h3>
                    <div class="panel-tools">
                        <span class="muted">Showing 50 per page</span>
                        <a href="/diary1" class="inline-edit-link">View all</a>
                    </div>
                </div>

                <% if (!pendingDiary1.length) { %>
                    <p class="empty-state">No pending Diary 1 entries.</p>
                    <% } else { %>
                        <% const groupedLatestDiary1=pendingDiary1.reduce((groups, entry)=> {
                            const key = formatDateDisplay(entry.entryDate);
                            if (!groups[key]) {
                            groups[key] = [];
                            }
                            groups[key].push(entry);
                            return groups;
                            }, {}); %>

                            <div class="record-groups compact-record-groups">
                                <% Object.entries(groupedLatestDiary1).forEach(([date, entries])=> { %>
                                    <article class="record-day">
                                        <div class="record-day-header">
                                            <h4>
                                                <%= date %> <span class="muted">
                                                        <%= entries[0].day %>
                                                    </span>
                                            </h4>
                                        </div>
                                        <div class="table-wrap">
                                            <table>
                                                <thead>
                                                    <tr>
                                                        <th>Name</th>
                                                        <th>Qt</th>
                                                        <th>Place</th>
                                                        <th>Pending</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% entries.forEach((entry, index)=> { %>
                                                        <tr>
                                                            <td><a href="/diary1/<%= entry._id %>/edit"
                                                                    class="entry-link">
                                                                    <%= entry.name %>
                                                                </a></td>
                                                            <td class="qt-cell">
                                                                <%= entry.quantity %>
                                                                    <%= entry.vehicleType==="Tractor" ? "T" : "D" %>
                                                            </td>
                                                            <td>
                                                                <%= entry.city %>
                                                            </td>
                                                            <td>
                                                                <%= entry.total %>
                                                                    <button
                                                                        type="button"
                                                                        class="payment-badge quick-pay-trigger remaining-badge amount-badge"
                                                                        data-entry-id="<%= entry._id %>"
                                                                        data-entry-name="<%= entry.name %>"
                                                                        data-total="<%= entry.total %>"
                                                                        data-paid-amount="<%= entry.paidAmount %>">
                                                                        <%= entry.paidAmount> 0 ? entry.total -
                                                                            entry.paidAmount : "Unpaid" %>
                                                                    </button>
                                                            </td>
                                                        </tr>
                                                        <% }) %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </article>
                                    <% }) %>
                            </div>

                            <div class="pagination-bar">
                                <span class="muted">Page <%= pendingDiary1Pagination.page %> of <%= pendingDiary1Pagination.totalPages %></span>
                                <div class="pagination-actions">
                                    <% if (pendingDiary1Pagination.hasPreviousPage) { %>
                                        <a class="secondary-btn" href="<%= buildDashboardUnpaidPageUrl(pendingDiary1Pagination.previousPage) %>">Previous</a>
                                    <% } else { %>
                                        <span class="secondary-btn pagination-disabled" aria-disabled="true">Previous</span>
                                    <% } %>

                                    <% if (pendingDiary1Pagination.hasNextPage) { %>
                                        <a class="secondary-btn" href="<%= buildDashboardUnpaidPageUrl(pendingDiary1Pagination.nextPage) %>">Next</a>
                                    <% } else { %>
                                        <span class="secondary-btn pagination-disabled" aria-disabled="true">Next</span>
                                    <% } %>
                                </div>
                            </div>
                            <% } %>
            </article>
        </section>
    </main>
    <footer class="site-footer">
        <p>Made with &#10084; by Champ</p>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/app.js"></script>
</body>

</html>
